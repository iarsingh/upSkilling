# Copy this file to .env and fill in real values. Never commit .env.

# Local Ollama (used to answer free-text screening questions / write short cover notes)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Login credentials are NOT stored here. On first run for a site, a real
# Chromium window opens and you log in by hand (including any 2FA/OTP).
# The session is then saved to browser-data/<site>/ and reused headlessly
# on every future run, so you only log in once per site until the cookie expires.

# Optional: cap how many applications a single run submits, per site.
MAX_APPLICATIONS_PER_RUN=25
