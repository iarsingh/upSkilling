# Copy this file to .env and fill values before uploading.

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=90000

# Local settings
TIMEZONE=Asia/Kolkata
YOUTUBE_DEFAULT_TOPIC=MLOps project explained with local Ollama, Kubernetes, observability, and CI/CD

# YouTube API publishing
# Create an OAuth client in Google Cloud Console with the YouTube Data API v3 enabled.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/youtube/callback
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_REFRESH_TOKEN=

# Upload safety default. Use private, unlisted, or public.
YOUTUBE_PRIVACY_STATUS=private
