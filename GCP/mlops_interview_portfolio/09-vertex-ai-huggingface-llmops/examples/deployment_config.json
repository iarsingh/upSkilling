{
  "target": "vertex-ai-endpoint",
  "region": "us-central1",
  "artifact_registry_image": "us-central1-docker.pkg.dev/example/ml-serving/hf-sentiment:2026-05-31",
  "machine_type": "n1-standard-4",
  "min_replica_count": 1,
  "max_replica_count": 3,
  "traffic_split_percent": 10,
  "prediction_logging": {
    "enabled": true,
    "bigquery_table": "mlops.prediction_logs"
  },
  "monitoring": {
    "enabled": true,
    "alert_topic": "projects/example/topics/ml-platform-alerts"
  },
  "rollback": {
    "enabled": true,
    "previous_model_version": "hf-sentiment-2026-05-15"
  }
}
