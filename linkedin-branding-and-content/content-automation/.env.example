# Copy this file to .env and fill values before publishing.

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=90000

# LinkedIn API publishing
# Generate an access token from your LinkedIn developer app.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/callback
LINKEDIN_SCOPES=openid profile email w_member_social
# If your app has not enabled "Sign In with LinkedIn using OpenID Connect",
# use only: LINKEDIN_SCOPES=w_member_social
LINKEDIN_ACCESS_TOKEN=

# Instagram API with Instagram Login
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
# Optional. Leave blank to use Meta's current default API version.
INSTAGRAM_API_VERSION=
# Meta downloads Reel videos from this public HTTPS location.
INSTAGRAM_REEL_BASE_URL=https://raw.githubusercontent.com/iarsingh/upSkilling/main/linkedin-branding-and-content/content-automation/reel-generator/output

# Your public profile URL. This is not enough for API posting, but it is kept
# with the content calendar for ownership/context.
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/iamarsingh/

# Example: urn:li:person:YOUR_PERSON_ID
# You can also use an organization URN if your app/account has permission.
LINKEDIN_AUTHOR_URN=

# Posting behavior
POST_TIME=06:00
TIMEZONE=Asia/Kolkata
LINKEDIN_ATTACH_IMAGES=false
