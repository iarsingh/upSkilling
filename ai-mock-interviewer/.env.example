NODE_ENV=production
HOST=0.0.0.0
PORT=3030
OFFLINE_ONLY=1
OLLAMA_KEEP_ALIVE=30m

# Durable account storage. Use a PostgreSQL connection string from your host.
# When omitted, local development falls back to data/users.json.
DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_SSL=true
DATABASE_POOL_SIZE=5

# Required in production so login sessions survive server restarts.
SESSION_SECRET=replace-with-a-long-random-secret
