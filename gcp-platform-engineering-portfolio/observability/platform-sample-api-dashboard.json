          "refId": "A"
        },
        {
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=\"platform-demo\",horizontalpodautoscaler=\"platform-sample-api\"}",
          "legendFormat": "desired",
          "refId": "B"
        }
      ],
      "title": "HPA Replicas",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 7,
      "targets": [
        {
          "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=\"platform-demo\",pod=~\"platform-sample-api-.*\"}[15m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Pod Restarts (15m)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 8,
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"platform-demo\",deployment=\"platform-sample-api\"}",
          "legendFormat": "available",
          "refId": "A"
        },
        {
          "expr": "kube_deployment_spec_replicas{namespace=\"platform-demo\",deployment=\"platform-sample-api\"}",
          "legendFormat": "desired",
          "refId": "B"
        }
